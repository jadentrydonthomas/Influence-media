# ---- required for real use ----
# Anthropic API key — powers Ask Trydon (agentic chat, tools), the Thesis
# Debater, AI-Signal ranking, briefings. Without it the deck still runs;
# chat falls back to a local quick parser and feeds show raw headlines.
ANTHROPIC_API_KEY=

# Access code for login (pick anything). If unset the deck runs OPEN — fine
# on localhost, never for a public deployment.
TRYDON_ACCESS_CODE=

# ---- recommended ----
# Your timezone (IANA name) — drives the calendar, briefings, quiet hours.
TRYDON_TZ=America/Indiana/Indianapolis
# When the morning briefing lands (24h HH:MM local time).
TRYDON_BRIEFING_TIME=06:30

# ---- optional ----
# Main brain — the chat assistant + station specialists (default claude-sonnet-5).
ANTHROPIC_MODEL=
# Fast lane — cheap/quick model for high-frequency background jobs (news
# sentiment, AI-signal ranking, thesis suggestions). Default claude-haiku-4-5.
ANTHROPIC_FAST_MODEL=
# YouTube Data API v3 key → live subs/views on the Media station.
YOUTUBE_API_KEY=
# YouTube channel (handle like @yourname, or UC… id) if you don't want to
# set it through the assistant.
YOUTUBE_CHANNEL=
# Where the SQLite DB lives (default ./data). Point at a persistent disk in production.
TRYDON_DATA_DIR=
# Port (default 8321).
PORT=
# Set to 1 only when serving plain HTTP on localhost (drops the Secure cookie flag).
TRYDON_INSECURE_COOKIE=
